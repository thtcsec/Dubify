### Core processing modes
# PROCESSING_ENGINE: local | cloud
PROCESSING_ENGINE=local
# PROCESSING_MODE: offline | hybrid | online
PROCESSING_MODE=hybrid

### CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

### Security (optional — leave empty for local dev)
API_ADMIN_KEY=

### Storage
CLEANUP_TEMP=true
ENABLE_STUDIO_BGM=true
STUDIO_BGM_VOLUME=0.15
# Studio HTML scenes: auto | playwright | hyperframes (Node.js 22+ for hyperframes)
STUDIO_RENDER_ENGINE=auto
# LLM for Studio "AI rewrite" — catalog id or auto (groq:llama-3.3-70b-versatile, openai:gpt-4o-mini, gemini:gemini-2.0-flash, …)
LLM_MODEL=auto
# AI Research Video: optional Pexels key (else Unsplash source); target voiceover seconds
PEXELS_API_KEY=
RESEARCH_VIDEO_TARGET_SECONDS=45
# Web Search for real-time news in Research Video
# Providers: tavily (recommended), brave, google, duckduckgo, auto (tries DDG free)
SEARCH_PROVIDER=auto
# Tavily: https://tavily.com (free tier: 1000 searches/month)
# Brave: https://brave.com/search/api/
SEARCH_API_KEY=
# Google Custom Search: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_CX=

### LLM provider keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
FAL_KEY=
FAL_AI_API_KEY=
PIXVERSE_API_KEY=your-pixverse-api-key
PIXVERSE_API_BASE=https://api.pixverse.ai
PIXVERSE_TIMEOUT_SECONDS=45

### Translation (optional — default: Google Translate)
# DeepL: highest quality for European languages. Get key at https://www.deepl.com/pro-api
# Use service_type=deepl in code or set as default when key is present
DEEPL_API_KEY=

### TTS (optional — default: Edge-TTS)
# OpenAI TTS: highest quality neural voices (requires OPENAI_API_KEY above)
OPENAI_TTS_MODEL=tts-1
# Voices: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=nova
# Kokoro TTS: local OpenAI-compatible server (high quality offline)
KOKORO_API_URL=
# Supertonic TTS: lightning-fast on-device 31-language TTS (pip install 'supertonic[serve]')
# Run: supertonic serve --host 127.0.0.1 --port 7788
SUPERTONIC_API_URL=
# ElevenLabs: professional voice cloning
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2

### Audio Preprocessing (optional)
# Enable UVR vocal separation before ASR (improves accuracy for noisy videos)
ENABLE_AUDIO_PREPROCESSING=false
AUDIO_PREPROCESS_MODEL=UVR-MDX-NET-Inst_HQ_4

### Studio Visual Effects
STUDIO_GRAIN_ENABLED=true
STUDIO_VIGNETTE_ENABLED=true
STUDIO_GRAIN_SEED=42

### Resource Limits (concurrent processes)
MAX_CONCURRENT_PLAYWRIGHT=2
MAX_CONCURRENT_FFMPEG=3
MAX_GPU_JOBS=1

### Whisper / NLLB defaults (optional overrides)
DEFAULT_WHISPER_MODEL=base
DEFAULT_NLLB_MODEL=facebook/nllb-200-distilled-600M

### GPU (RTX / CUDA) — requires CUDA-enabled PyTorch for Whisper/NLLB on GPU
USE_GPU=true
WHISPER_DEVICE=auto
VIDEO_ENCODER=auto
NLLB_USE_GPU=true

# --- Advanced Processing Features ---
# Enables using Demucs to separate background music and keep it in the final dub
ENABLE_BGM_RETENTION=False

# (Optional) External WhisperX API endpoint for speaker diarization
# Example: http://127.0.0.1:9092/v1
WHISPERX_API_URL=

# (Optional) External F5-TTS API endpoint for Voice Cloning (Zero-shot TTS)
# Example: http://127.0.0.1:7860/
F5TTS_API_URL=


### Downloader settings
YTDLP_COOKIES_FROM_BROWSERS=chrome,edge,firefox
YTDLP_COOKIE_FILE=
YTDLP_PROXY=
YTDLP_SOCKET_TIMEOUT=20

### Douyin/TikTok fallback parser (optional)
DOUYIN_FALLBACK_API_BASE=
DOUYIN_FALLBACK_API_KEY=
